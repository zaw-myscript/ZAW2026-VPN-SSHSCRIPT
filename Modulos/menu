function limit1 () {
   clear
   echo -e "\n\033[1;32mINICIANDO O LIMITER... \033[0m\n"
   fun_bar 'screen -dmS limiter limiter' 'sleep 3'
   [[ $(grep -wc "limiter" /etc/autostart) = '0' ]] && { echo -e "ps x | grep 'limiter' | grep -v 'grep' && echo 'ON' || screen -dmS limiter limiter" >> /etc/autostart; } || { sed -i '/limiter/d' /etc/autostart; echo -e "ps x | grep 'limiter' | grep -v 'grep' && echo 'ON' || screen -dmS limiter limiter" >> /etc/autostart; }
   echo -e "\n\033[1;32m  LIMITER ATIVO !\033[0m"
   sleep 3
}

function limit2 () {
   clear
   echo -e "\033[1;32mPARANDO O LIMITER... \033[0m\n"
   fun_stplimiter () { sleep 1; screen -r -S "limiter" -X quit; screen -wipe 1>/dev/null 2>/dev/null; [[ $(grep -wc "limiter" /etc/autostart) != '0' ]] && { sed -i '/limiter/d' /etc/autostart; }; sleep 1; }
   fun_bar 'fun_stplimiter' 'sleep 3'
   echo -e "\n\033[1;31m LIMITER PARADO !\033[0m"
   sleep 3
}

function limit_ssh () {
[[ $(ps x | grep "limiter"|grep -v grep |wc -l) = '0' ]] && limit1 || limit2
}

function autoexec () {
   if grep "menu;" /etc/profile > /dev/null; then
      clear; echo -e "\033[1;32mDESATIVANDO AUTO EXECUÇÃO\033[0m"
      offautmenu () { sed -i '/menu;/d' /etc/profile; }
      echo ""; fun_bar 'offautmenu'; echo ""
      echo -e "\033[1;31mAUTO EXECUÇÃO DESATIVADO!\033[0m"; sleep 1.5s
   else
      clear; echo -e "\033[1;32mATIVANDO AUTO EXECUÇÃO\033[0m"
      autmenu () { grep -v "^menu;" /etc/profile > /tmp/tmpass && mv /tmp/tmpass /etc/profile; echo "menu;" >> /etc/profile; }
      echo ""; fun_bar 'autmenu'; echo ""
      echo -e "\033[1;32mAUTO EXECUÇÃO ATIVADO!\033[0m"; sleep 1.5s
   fi
}

function mudar_dns () {
   clear
   echo -e "\E[44;1;37m        🌐 အလွယ်တကူ DNS ပြောင်းရန် (CHANGE DNS) 🌐         \E[0m"
   echo ""
   echo -e "\033[1;33m[ 1 ]\033[1;37m ➔ Google DNS (8.8.8.8, 8.8.4.4)"
   echo -e "\033[1;33m[ 2 ]\033[1;37m ➔ Cloudflare DNS (1.1.1.1, 1.0.0.1)"
   echo -e "\033[1;33m[ 3 ]\033[1;37m ➔ ကိုယ်တိုင်ထည့်မည် (Custom DNS)"
   echo -e "\033[1;33m[ 0 ]\033[1;37m ➔ နောက်သို့ (Back)"
   echo ""
   echo -ne "\033[1;32m➔ ရွေးချယ်ရန် \033[1;33m?\033[1;37m : "; read opdns
   case $opdns in
      1) dns1="8.8.8.8"; dns2="8.8.4.4" ;;
      2) dns1="1.1.1.1"; dns2="1.0.0.1" ;;
      3) echo -ne "\n\033[1;32mPrimary DNS ထည့်ပါ : \033[1;37m"; read dns1; echo -ne "\033[1;32mSecondary DNS ထည့်ပါ : \033[1;37m"; read dns2 ;;
      0) return ;;
      *) echo -e "\n\033[1;31mမှားယွင်းနေပါသည်။ ပြန်ရွေးပါ!\033[0m"; sleep 2; mudar_dns; return ;;
   esac
   chattr -i /etc/resolv.conf > /dev/null 2>&1
   rm -f /etc/resolv.conf > /dev/null 2>&1
   echo "nameserver $dns1" > /etc/resolv.conf
   echo "nameserver $dns2" >> /etc/resolv.conf
   chattr +i /etc/resolv.conf > /dev/null 2>&1
   echo -e "\n\033[1;32m🎉 DNS ပြောင်းလဲခြင်း အောင်မြင်ပါသည်!\033[0m"
