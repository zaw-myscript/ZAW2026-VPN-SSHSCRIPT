#!/bin/bash
export DEBIAN_FRONTEND=noninteractive

# --- Progress Bar Function ---
fun_bar () {
comando[0]="$1"; comando[1]="$2"
 ( [[ -e $HOME/fim ]] && rm $HOME/fim; ${comando[0]} -y > /dev/null 2>&1; ${comando[1]} -y > /dev/null 2>&1; touch $HOME/fim ) > /dev/null 2>&1 &
 tput civis
 echo -ne "\033[1;33m["
 while true; do
   for((i=0; i<18; i++)); do echo -ne "\033[1;31m#"; sleep 0.1s; done
   [[ -e $HOME/fim ]] && rm $HOME/fim && break
   echo -e "\033[1;33m]"; sleep 1s; tput cuu1; tput dl1; echo -ne "\033[1;33m["
 done
 echo -e "\033[1;33m]\033[1;37m -\033[1;32m OK !\033[1;37m"
 tput cnorm
}

IP=$(wget -qO- ipv4.icanhazip.com 2>/dev/null)

# --- Menu Logic ---
menu () {
