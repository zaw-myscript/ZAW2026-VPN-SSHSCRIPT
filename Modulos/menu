[[ ! -f /etc/vps_country ]] && echo $(wget -qO- ip-api.com/line?fields=country 2>/dev/null || echo "Unknown") > /etc/vps_country
_country=$(cat /etc/vps_country)
_system=$(cut -d' ' -f1 /etc/issue.net)
[[ -f /etc/domain ]] && _domain=$(cat /etc/domain) || _domain="No-Domain"
_hora=$(date +%H:%M:%S)
_ons=$(ps -x | grep sshd | grep -v root | grep priv | wc -l)

