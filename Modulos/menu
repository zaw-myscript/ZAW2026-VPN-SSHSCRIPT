echo -e "\033[1;36m┣━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┫\033[0m"
echo -e "\033[1;36m┃ \033[1;33mIP     :\033[1;37m $IP   \033[1;33mServer:\033[1;37m $_country\033[0m"
echo -e "\033[1;36m┃ \033[1;33mDomain :\033[1;36m ✦ $_domain ✦\033[0m"
