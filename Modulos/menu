#limiter
function limit1 () {
   clear
   echo -e "\n\033[1;32mINICIANDO O LIMITER... \033[0m"
   echo ""
   fun_bar 'screen -dmS limiter limiter' 'sleep 3'
   [[ $(grep -wc "limiter" /etc/autostart) = '0' ]] && {
       echo -e "ps x | grep 'limiter' | grep -v 'grep' && echo 'ON' || screen -dmS limiter limiter" >> /etc/autostart
   }
   echo -e "\n\033[1;32m  LIMITER ATIVO !\033[0m"
   sleep 3; menu
}
function limit2 () {
   clear
   echo -e "\033[1;32mPARANDO O LIMITER... \033[0m"
   echo ""
   fun_stplimiter () {
      screen -r -S "limiter" -X quit; screen -wipe 1>/dev/null 2>/dev/null
      sed -i '/limiter/d' /etc/autostart
   }
   fun_bar 'fun_stplimiter' 'sleep 3'
   echo -e "\n\033[1;31m LIMITER PARADO !\033[0m"
   sleep 3; menu
}
function limit_ssh () {
[[ $(ps x | grep "limiter"|grep -v grep |wc -l) = '0' ]] && limit1 || limit2
}

function autoexec () {
   if grep "menu;" /etc/profile > /dev/null; then
      clear; sed -i '/menu;/d' /etc/profile
      echo -e "\033[1;31mAUTO EXECUГҮГғO DESATIVADO!\033[0m"; sleep 1.5s; menu2
   else
      clear; echo "menu;" >> /etc/profile
      echo -e "\033[1;32mAUTO EXECUГҮГғO ATIVADO!\033[0m"; sleep 1.5s; menu2
   fi
}

