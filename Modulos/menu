echo -e "\033[1;35m[00] \033[1;31mSAIR\n"
echo -ne "\033[1;32m➔ O QUE DESEJA FAZER \033[1;33m?\033[1;37m : \033[0m"; read x

case "$x" in
   1|01) clear; echo "User logic..."; sleep 2; menu ;;
   2) clear; echo "Testing speed..."; sleep 2; menu ;;
